# SubSieve 配置模板 — Cloudflare Tunnel / 反向代理 部署
# 用法：cp .env.example .env  然后填入真实值
# ⚠ .env 含敏感信息，已被 .gitignore 忽略，切勿提交

# ── 机场后端（订阅清洗后反代到此）──
V2B_BACKEND=https://panel.your-airport.com
V2B_HOST=panel.your-airport.com
SUBSCRIBE_PATH=/api/v1/client/subscribe
GATEWAY_PORT=443

# ── 反代后客户端使用的公网订阅域名（后台“订阅链接”卡片展示用，可留空）──
# 例如经 Cloudflare Tunnel 暴露的域名；留空则后台不展示该卡片
GATEWAY_PUBLIC_URL=https://sub.your-domain.com

# ── 真实客户端 IP（Cloudflare Tunnel / CDN 关键项）──
# cloudflared / CDN 从本机回源，必须信任回源地址并读取真实 IP 头，
# 否则日志、云IP识别、黑白名单、速率限制会全部按回源IP生效，拦截层形同虚设。
# 注意：经 Docker 发布端口回源时，容器看到的源是 docker 网桥网关（172.x），
#       故需把网桥段一并加入信任列表。
# Cloudflare 用 CF-Connecting-IP；其它反代按需改为 X-Forwarded-For / X-Real-IP。
AXISNOW_TRUSTED_IPS=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16
REAL_IP_HEADER=CF-Connecting-IP

# ── 管理后台凭证（首次部署可留空由脚本生成；之后建议在后台修改）──
ADMIN_USER=admin
ADMIN_PASS=
ADMIN_SECRET_PATH=
GATEWAY_CONTAINER=subscribe-gateway
